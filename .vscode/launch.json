{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "1. Run Data Pipeline",
      "type": "python",
      "request": "launch",
      "module": "data.pipeline",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "2. Run Feature Engineering",
      "type": "python",
      "request": "launch",
      "module": "data.features",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "3. Train Model",
      "type": "python",
      "request": "launch",
      "module": "models.train",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "4. Run Backtest",
      "type": "python",
      "request": "launch",
      "module": "backtest.engine",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "5. Run Live Bot",
      "type": "python",
      "request": "launch",
      "module": "execution.live_bot",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Run Main (Full Flow)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}
